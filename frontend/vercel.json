{
  "rewrites": [
    { "source": "/solve-math-problems",     "destination": "/pages/solve-math-problems.html" },
    { "source": "/ai-homework-helper",       "destination": "/pages/ai-homework-helper.html" },
    { "source": "/explain-math-step-by-step","destination": "/pages/explain-math-step-by-step.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
